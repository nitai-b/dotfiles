alias vim="nvim"
alias s="~/.scriptsAndDotfiles/tmux-sessionizer.sh"
alias python="python3"

alias tracker="~/projects/personal/project-time-tracker/run_local.sh"

alias ixm.shp-core.zip="cd ~/projects/ixm/; rm -rf shp-core-platform.zip; zip -r shp-core-platform.zip shp-core-platform -x 'shp-core-platform/data/*' 'shp-core-platform/.venv/*' 'shp-core-platform/frontend/node_modules/*'; cd"
alias opifex.laravel.zip="cd ~/projects/clients && rm -f payroll-app-laravel.zip && zip -r payroll-app-laravel.zip payroll-app-laravel -x \
'payroll-app-laravel/.github/*' \
'payroll-app-laravel/.gitattributes/*' \
'payroll-app-laravel/vendor/*' \
'payroll-app-laravel/node_modules/*' \
'payroll-app-laravel/.history/*' \
'payroll-app-laravel/.playwright-mcp/*' \
'payroll-app-laravel/playwright-report/*' \
'payroll-app-laravel/test-results/*' \
'payroll-app-laravel/storage/logs/*' \
'payroll-app-laravel/storage/framework/*' \
'payroll-app-laravel/bootstrap/cache/*' \
'payroll-app-laravel/bootstrap/ssr/*' \
'payroll-app-laravel/public/build/*' \
'payroll-app-laravel/storage/app/private/*' \
'payroll-app-laravel/.env' \
'payroll-app-laravel/.php-cs-fixer.dist.php' \
'payroll-app-laravel/.php-cs-fixer.cache' \
'payroll-app-laravel/.php-cs-fixer.cache' \
&& cd - >/dev/null"
